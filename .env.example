# URL of your AzuraCast instance (no trailing slash)
# For local Docker setup use: http://azuracast (internal service name)
# For external deployments use: https://your-azuracast-domain.com
NEXT_PUBLIC_AZURACAST_BASE_URL=https://your-azuracast-domain.com

# Short name (shortcode) of the station to display by default
# Find this in AzuraCast > Station > Edit > Short Name
NEXT_PUBLIC_AZURACAST_STATION_SHORT_NAME=your_station_shortcode

# Force white/light text regardless of system preference ("true" | "false")
# Set to "true" if your background is always dark
NEXT_PUBLIC_FORCE_WHITE_TEXT=false
